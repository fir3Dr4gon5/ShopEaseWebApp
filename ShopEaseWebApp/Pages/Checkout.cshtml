@page
@model ShopEaseWebApp.Pages.CheckoutModel
@{
    ViewData["Title"] = "Checkout";
}

<h1>Checkout</h1>

@if (Model.PaymentCancelled)
{
    <div class="alert alert-warning" role="alert">
        Payment was cancelled. You can review your details and try again.
    </div>
}

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<h3>Order Summary</h3>
<table>
    <thead>
        <tr>
            <th>Product</th>
            <th>Quantity</th>
            <th>Subtotal</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.CartItems)
        {
            <tr>
                <td>@item.Product.Name</td>
                <td>@item.Quantity</td>
                <td>£@(item.Product.Price * item.Quantity)</td>
            </tr>
        }
    </tbody>
</table>

<p>Total: £@Model.Total</p>

<h3>Shipping Details</h3>
<form method="post">
    <div>
        <label>Address</label>
        <input asp-for="ShippingAddress" />
    </div>
    <div>
        <label>City</label>
        <input asp-for="City" />
    </div>
    <div>
        <label>Post Code</label>
        <input asp-for="PostCode" />
    </div>
<button type="submit">Continue to Secure Payment</button>
</form>