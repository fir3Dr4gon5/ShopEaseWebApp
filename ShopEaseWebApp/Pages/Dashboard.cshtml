@page
@model ShopEaseWebApp.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<h1>Dashboard</h1>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info" role="alert">
        @Model.StatusMessage
    </div>
}

@if (!Model.Users.Any())
{
    <p>No users found.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Email</th>
                <th>Current Role</th>
                <th>Change Role</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td>@user.Email</td>
                    <td>@user.CurrentRole</td>
                    <td>
                        <form method="post" asp-page-handler="UpdateRole" asp-route-userId="@user.Id" class="d-flex gap-2">
                            <select name="SelectedRole" class="form-select">
                                @foreach (var role in Model.AvailableRoles)
                                {
                                    if (role == user.CurrentRole)
                                    {
                                        <option value="@role" selected>@role</option>
                                    }
                                    else
                                    {
                                        <option value="@role">@role</option>
                                    }
                                }
                            </select>
                            <button type="submit" class="btn btn-primary">Save</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
