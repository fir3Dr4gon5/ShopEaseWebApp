@page
@model ShopEaseWebApp.Pages.OrderConfirmationModel
@{
    ViewData["Title"] = "Order Confirmation";
}

<div class="shop-flow-page order-confirmation-page">
    <a asp-page="/Products" class="btn btn-outline-secondary btn-sm mb-3">Back to products</a>

    <h1 class="h3 mb-4">Order confirmation</h1>

    @if (Model.IsPending)
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-4 p-lg-5 text-center">
                <div class="alert alert-info border-0 mb-4" role="alert">
                    Payment received. We are finalising your order now.
                </div>
                <p class="text-muted mb-4">If this page does not update within a few seconds, refresh it.</p>
                @if (!string.IsNullOrWhiteSpace(Model.SessionId))
                {
                    <a class="btn btn-primary" asp-page="/OrderConfirmation" asp-route-sessionId="@Model.SessionId">Refresh status</a>
                }
            </div>
        </div>
    }
    else if (Model.Order is not null)
    {
        <div class="alert alert-success border-0 shadow-sm mb-4" role="alert">
            Thank you. Your payment was successful and your order is confirmed.
        </div>

        <div class="row g-4">
            <div class="col-lg-5">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body p-4">
                        <h2 class="h6 text-uppercase text-muted mb-3">Order details</h2>
                        <dl class="row mb-0 small">
                            <dt class="col-sm-4 text-muted">Order #</dt>
                            <dd class="col-sm-8">@Model.Order.Id</dd>
                            <dt class="col-sm-4 text-muted">Status</dt>
                            <dd class="col-sm-8">@Model.Order.Status</dd>
                            <dt class="col-sm-4 text-muted">Total</dt>
                            <dd class="col-sm-8"><span class="order-total-display fs-5">£@Model.Order.TotalAmount.ToString("0.00")</span></dd>
                            <dt class="col-sm-4 text-muted">Shipping</dt>
                            <dd class="col-sm-8">@Model.Order.ShippingAddress, @Model.Order.City, @Model.Order.PostCode</dd>
                        </dl>
                    </div>
                </div>
            </div>
            <div class="col-lg-7">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body p-0">
                        <div class="px-4 pt-4 pb-2">
                            <h2 class="h5 mb-0">Items</h2>
                        </div>
                        <ul class="list-group list-group-flush">
                            @foreach (var item in Model.Order.OrderItems)
                            {
                                var lineTotal = item.PriceAtPurchase * item.Quantity;
                                <li class="list-group-item px-4 py-3">
                                    <div class="d-flex gap-3">
                                        <div class="line-item-img-wrap line-item-img-wrap--compact">
                                            @if (!string.IsNullOrWhiteSpace(item.Product.ImageUrl))
                                            {
                                                <img src="@item.Product.ImageUrl" alt="@item.Product.Name" />
                                            }
                                            else
                                            {
                                                <span class="line-item-no-img">No image</span>
                                            }
                                        </div>
                                        <div class="flex-grow-1 min-w-0">
                                            <div class="fw-semibold">@item.Product.Name</div>
                                            <div class="text-muted small">Qty @item.Quantity × £@item.PriceAtPurchase.ToString("0.00")</div>
                                        </div>
                                        <div class="line-item-price small text-nowrap align-self-start">£@lineTotal.ToString("0.00")</div>
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4">
            <a asp-page="/Products" class="btn btn-primary">Continue shopping</a>
        </div>
    }
</div>
