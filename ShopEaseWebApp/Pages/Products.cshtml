@page
@model ShopEaseWebApp.Pages.ProductsModel
@{
}
<h1 class="mb-4">Our Products</h1>

<div class="products-page">
    
    <form method="get" class="mb-4">
        <label asp-for="SearchTerm" class="form-label">Search products</label>
        <div class="input-group">
            <input asp-for="SearchTerm" class="form-control" placeholder="Search by name or description" />
            <button type="submit" class="btn btn-outline-primary">Search</button>
            @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
            {
                <a asp-page="/Products" class="btn btn-outline-secondary">Clear</a>
            }
        </div>
    </form>

    @if (Model.RecommendedProducts.Any())
    {

        

        <section class="mb-5">
            <h2 class="h4 mb-3">Recommended for you</h2>
            <div class="row row-cols-1 row-cols-md-3 g-4">
                @foreach (var product in Model.RecommendedProducts)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm">
                            <div class="product-card-img">
                                @if (!string.IsNullOrWhiteSpace(product.ImageUrl))
                                {
                                    <img src="@product.ImageUrl" alt="@product.Name" />
                                }
                            </div>
                            <div class="card-body d-flex flex-column">
                                <h3 class="card-title h5">@product.Name</h3>
                                <p class="card-text text-muted small flex-grow-1">@product.Description</p>
                                <p class="card-text mb-1"><strong>£@product.Price</strong></p>
                                <p class="card-text small text-muted mb-3">Category: @product.Category</p>
                                <a class="btn btn-primary mt-auto" asp-page="/ProductDetails" asp-route-id="@product.Id">View details</a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    

    @if (!Model.Products.Any())
    {
        <div class="alert alert-light border" role="status">
            No products found for "<strong>@Model.SearchTerm</strong>".
        </div>
    }
    <h2 class="h4 mb-3">Products</h2>

    <div class="row row-cols-1 row-cols-md-3 g-4">
    
        @foreach (var product in Model.Products)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="product-card-img">
                        @if (!string.IsNullOrWhiteSpace(product.ImageUrl))
                        {
                            <img src="@product.ImageUrl" alt="@product.Name" />
                        }
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h2 class="card-title h5">@product.Name</h2>
                        <p class="card-text text-muted small flex-grow-1">@product.Description</p>
                        <p class="card-text mb-1"><strong>£@product.Price</strong></p>
                        <p class="card-text small text-muted mb-1">Category: @product.Category</p>
                        <p class="card-text small text-muted mb-3">In stock: @product.StockQuantity</p>
                        <a class="btn btn-primary mt-auto" asp-page="/ProductDetails" asp-route-id="@product.Id">View details</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>