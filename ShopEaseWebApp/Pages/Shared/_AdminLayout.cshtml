@{
    Layout = "_Layout";
    var path = Context.Request.Path.Value ?? "";
    string ActiveClass(string routePath) =>
        string.Equals(path, routePath, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}
<div class="admin-toolbar border-bottom pb-3 mb-4">
    <div class="dropdown">
        <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" id="adminMenuButton">
            Admin
        </button>
        <ul class="dropdown-menu" aria-labelledby="adminMenuButton">
            <li><a class="dropdown-item @ActiveClass("/Admin/Users")" asp-page="/Admin/Users">Users</a></li>
            <li><a class="dropdown-item @ActiveClass("/Admin/Orders")" asp-page="/Admin/Orders">Orders</a></li>
            <li><a class="dropdown-item @ActiveClass("/Admin/Tickets")" asp-page="/Admin/Tickets">Tickets</a></li>
        </ul>
    </div>
</div>
@RenderBody()
